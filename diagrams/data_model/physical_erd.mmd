    DIM_DATE {
        NUMBER_8  DATE_KEY PK
        DATE      FULL_DATE
        NUMBER    DAY
        NUMBER    MONTH
        VARCHAR   MONTH_NAME
        NUMBER    QUARTER
        NUMBER    YEAR
        VARCHAR   YEAR_MONTH
        NUMBER    DAY_OF_WEEK
        BOOLEAN   IS_WEEKEND
        NUMBER    FISCAL_YEAR
        VARCHAR   FISCAL_QUARTER
        DATE      MONTH_START_DATE
    }
    DIM_PLAYER {
        NUMBER    PLAYER_KEY PK
        VARCHAR   PLAYER_ID
        DATE      REGISTRATION_DATE
        VARCHAR   REGION_CODE
        VARCHAR   KYC_STATUS
        VARCHAR   KYC_RISK_LEVEL
        BOOLEAN   PEP_FLAG
        BOOLEAN   WATCHLIST_FLAG
        BOOLEAN   SELF_EXCLUSION_FLAG
        VARCHAR   PLAYER_STATUS
        TIMESTAMP CREATED_AT
        TIMESTAMP UPDATED_AT
        VARCHAR   SOURCE_SYSTEM
    }
    DIM_ACCOUNT {
        NUMBER    ACCOUNT_KEY PK
        VARCHAR   ACCOUNT_ID
        NUMBER    PLAYER_KEY FK
        VARCHAR   ACCOUNT_TYPE
        VARCHAR   CURRENCY
        DATE      OPEN_DATE
        VARCHAR   ACCOUNT_STATUS
        VARCHAR   ACCOUNT_RISK_RATING
        VARCHAR   PRIMARY_FUNDING_METHOD
        TIMESTAMP CREATED_AT
        TIMESTAMP UPDATED_AT
        VARCHAR   SOURCE_SYSTEM
    }
    DIM_ALERT_TYPE {
        NUMBER    ALERT_TYPE_KEY PK
        VARCHAR   RULE_CODE
        VARCHAR   RULE_NAME
        VARCHAR   TYPOLOGY
        VARCHAR   DESCRIPTION
        NUMBER    BASE_RISK_SCORE
        VARCHAR   DEFAULT_SEVERITY
        VARCHAR   REGULATORY_REFERENCE
        BOOLEAN   IS_ACTIVE
    }
    DIM_STATUS {
        NUMBER    STATUS_KEY PK
        VARCHAR   STATUS_CODE
        VARCHAR   STATUS_NAME
        VARCHAR   STATUS_CATEGORY
        NUMBER    WORKFLOW_ORDER
        BOOLEAN   IS_TERMINAL
        VARCHAR   APPLIES_TO
    }
    DIM_ANALYST {
        NUMBER    ANALYST_KEY PK
        VARCHAR   ANALYST_ID
        VARCHAR   ANALYST_NAME
        VARCHAR   TEAM
        VARCHAR   SENIORITY
        BOOLEAN   ACTIVE_FLAG
        VARCHAR   SOURCE_SYSTEM
    }
    FACT_TRANSACTIONS {
        NUMBER    TRANSACTION_KEY PK
        VARCHAR   TRANSACTION_ID
        NUMBER_8  DATE_KEY FK
        NUMBER    PLAYER_KEY FK
        NUMBER    ACCOUNT_KEY FK
        NUMBER    COUNTERPARTY_ACCOUNT_KEY FK
        TIMESTAMP TRANSACTION_TIMESTAMP
        VARCHAR   TRANSACTION_TYPE
        VARCHAR   PAYMENT_FORMAT
        VARCHAR   CURRENCY
        NUMBER    AMOUNT
        NUMBER    AMOUNT_CAD
        BOOLEAN   IS_HIGH_RISK_METHOD
        VARCHAR   SOURCE_SYSTEM
        VARCHAR   LOAD_BATCH_ID
    }
    FACT_AML_ALERTS {
        NUMBER    ALERT_KEY PK
        VARCHAR   ALERT_ID
        NUMBER    TRANSACTION_KEY FK
        NUMBER    ALERT_TYPE_KEY FK
        NUMBER    PLAYER_KEY FK
        NUMBER    ACCOUNT_KEY FK
        NUMBER_8  DATE_KEY FK
        NUMBER    STATUS_KEY FK
        TIMESTAMP ALERT_TIMESTAMP
        VARCHAR   SEVERITY
        NUMBER    RISK_SCORE
        BOOLEAN   IS_ESCALATED
        VARCHAR   ALERT_DESCRIPTION
        VARCHAR   SOURCE_SYSTEM
    }
    FACT_STR_CASES {
        NUMBER    CASE_KEY PK
        VARCHAR   CASE_ID
        NUMBER    ALERT_KEY FK
        NUMBER    PLAYER_KEY FK
        NUMBER    ANALYST_KEY FK
        NUMBER    STATUS_KEY FK
        NUMBER_8  OPEN_DATE_KEY FK
        NUMBER_8  CLOSE_DATE_KEY FK
        VARCHAR   CASE_PRIORITY
        NUMBER    SLA_DAYS
        NUMBER    INVESTIGATION_DAYS
        BOOLEAN   SLA_BREACHED
        BOOLEAN   STR_SUBMITTED_FLAG
        VARCHAR   CLOSURE_REASON
        VARCHAR   SOURCE_SYSTEM
    }
    FACT_MARKET_PERFORMANCE {
        NUMBER    MARKET_PERF_KEY PK
        NUMBER_8  DATE_KEY FK
        VARCHAR   YEAR_MONTH
        VARCHAR   FISCAL_YEAR_QUARTER
        NUMBER    TOTAL_WAGERS
        NUMBER    TOTAL_GGR
        NUMBER    ACTIVE_ACCOUNTS
        NUMBER    GGR_PER_ACTIVE
        NUMBER    HOLD_PCT
        NUMBER    MOM_GGR_GROWTH_PCT
        VARCHAR   SOURCE_SYSTEM
        VARCHAR   LOAD_BATCH_ID
    }
