# ─── Secrets & credentials (NEVER commit) ───────────────────────────────
.env
.env.*
*.env
secrets.*
credentials.*
*_secret*
*.pem
*.key
*.p8
*.ppk
rsa_key*
snowflake_config*
connections.toml
config.toml
*.token

# ─── Snowflake / SnowSQL ────────────────────────────────────────────────
.snowsql/
snowsql_rt.log*
.snowflake/

# ─── Python / Snowpark ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
env/
.ipynb_checkpoints/
*.egg-info/
.pytest_cache/

# ─── Power BI ───────────────────────────────────────────────────────────
